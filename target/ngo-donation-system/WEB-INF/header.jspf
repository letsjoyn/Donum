<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>${pageTitle} | Donum</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
    <link rel="stylesheet" href="css/style.css">
</head>
<body>
    <nav>
        <a href="#" class="logo"><i class="fas fa-hands-holding-heart"></i> Donum</a>
        <div class="nav-links">
            <c:if test="${not empty sessionScope.user}">
                <c:if test="${sessionScope.user.role == 'Admin'}">
                    <a href="admin-dashboard.jsp" class="nav-link"><i class="fas fa-chart-line"></i> Dashboard</a>
                </c:if>
                <c:if test="${sessionScope.user.role == 'Donor'}">
                    <a href="donor-dashboard.jsp" class="nav-link"><i class="fas fa-hand-holding-heart"></i> My Donations</a>
                </c:if>
                <c:if test="${sessionScope.user.role == 'Volunteer'}">
                    <a href="volunteer-dashboard.jsp" class="nav-link"><i class="fas fa-truck"></i> Field Ops</a>
                </c:if>
                <a href="campaigns.jsp" class="nav-link"><i class="fas fa-bullhorn"></i> Campaigns</a>
                <div class="nav-user">
                    <span class="user-badge"><i class="fas fa-user-circle"></i> ${sessionScope.user.fullName}</span>
                    <span class="role-badge role-${fn:toLowerCase(sessionScope.user.role)}">${sessionScope.user.role}</span>
                    <a href="logout" class="btn-logout"><i class="fas fa-sign-out-alt"></i></a>
                </div>
            </c:if>
            <c:if test="${empty sessionScope.user}">
                <a href="login.jsp" class="nav-link">Login</a>
                <a href="register.jsp" class="btn-primary nav-btn">Get Started</a>
            </c:if>
        </div>
        <button class="mobile-toggle" onclick="document.querySelector('.nav-links').classList.toggle('active')">
            <i class="fas fa-bars"></i>
        </button>
    </nav>
    <main class="main-content">
